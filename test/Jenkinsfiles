pipeline {
    agent any

    environment {
        IMAGE_NAME = "blujaytech/nodeapp"
        IMAGE_TAG  = "${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout Source') {
            steps {
                git 'https://github.com/Blujaytech/nodeapp_test.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    docker.build("${IMAGE_NAME}:${IMAGE_TAG}")
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                script {

                    docker.withRegistry('', 'dockerhublogin') {

                        docker.image("${IMAGE_NAME}:${IMAGE_TAG}").push()

                        docker.image("${IMAGE_NAME}:${IMAGE_TAG}").push("latest")
                    }
                }
            }
        }

        stage('Deploy to EKS') {
            steps {

                sh '''
                cd /var/lib/jenkins/workspace/CICD-Project

                kubectl apply -f deploymentservice.yaml

                kubectl rollout restart deployment nodeapp-deployment

                kubectl get pods

                kubectl get svc
                '''
            }
        }
    }
}
